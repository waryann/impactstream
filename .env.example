# ─────────────────────────────────────────────────────────────────
# ImpactStream — Configuration (.env)
# Copiez ce fichier en .env et remplissez vos valeurs réelles.
# ⚠️  NE COMMITEZ JAMAIS le fichier .env (ajoutez-le dans .gitignore)
# ─────────────────────────────────────────────────────────────────

# ── LiveKit (Webinaire Ultra-Basse Latence) ──
# Créez un compte gratuit sur https://cloud.livekit.io
# Plan gratuit : 10 000 minutes/mois (suffisant pour un culte hebdomadaire)
#
LIVEKIT_URL=wss://your-project-xxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Flask ──
# SECRET_KEY=change-this-to-a-long-random-string

# ── PostgreSQL (Production Render) ──
# DATABASE_URL=postgresql://user:password@host:5432/dbname
